# ============================================
# CW-SmartMonitor Environment Variables Template
# ============================================
# Salin file ini menjadi .env.local lalu isi nilainya.
# JANGAN commit .env.local ke GitHub!

# Mode data: "simulation" | "hardware"
NEXT_PUBLIC_DATA_MODE=

# URL broker MQTT/WebSocket (untuk hardware mode, contoh: ws://192.168.1.x:9001)
NEXT_PUBLIC_MQTT_BROKER_URL=

# Kunci rahasia untuk validasi request dari ESP32
API_SECRET_KEY=

# Jarak (cm) ambang batas ghost booking (default: 60)
NEXT_PUBLIC_GHOST_THRESHOLD_CM=

# Delay (ms) sebelum status ghost dikonfirmasi (default: 3000)
NEXT_PUBLIC_GHOST_DELAY_MS=

# Jam maksimal booking sebelum overstay alert (default: 4)
NEXT_PUBLIC_OVERSTAY_HOURS=

# Menit tanpa aktivitas sebelum energy saver aktif (default: 30)
NEXT_PUBLIC_ENERGY_SAVER_MINUTES=

# Debounce sensor ultrasonik dalam ms (default: 3000)
NEXT_PUBLIC_SENSOR_DEBOUNCE_MS=
